# System info
neofetch-sak() {
    echo ""
    echo -e "\e[38;5;213m   в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—"
    echo -e "\e[38;5;213m   в•‘     рҹҢё  S A K L I N U X  рҹҢё     в•‘"
    echo -e "\e[38;5;213m   в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\e[0m"
    echo ""
    if command -v neofetch &> /dev/null; then
        neofetch --colors 213 206 251 141
    else
        echo "  OS: SakLinux (WSL2)"
        echo "  Kernel: $(uname -r)"
        echo "  Shell: $SHELL"
        echo "  Packages: $(dpkg -l 2>/dev/null | grep -c ^ii)"
    fi
}

# Sakura welcome
echo ""
echo -e "\e[38;5;213m  рҹҢё Welcome to SakLinux!\e[0m"
echo -e "\e[38;5;251m  Type \e[38;5;213m'saklinux-art'\e[38;5;251m for ASCII art"
echo -e "\e[38;5;251m  Type \e[38;5;213m'sak help'\e[38;5;251m for package manager"
echo -e "\e[38;5;251m  Type \e[38;5;213m'sak pet'\e[38;5;251m to meet your companion"
echo ""

# Zoxide
[ -f ~/.config/zsh/zshrc ] || eval "$(zoxide init bash 2>/dev/null)"

# FZF
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --info=inline --color=bg+:#3b254f,bg:#1a1a2e,spinner:#FF69B4,hl:#FF1493,fg:#FFB7C5,header:#FF1493,info:#C71585,pointer:#FF69B4,marker:#FFB7C5,fg+:#FFB7C5,prompt:#FF69B4,hl+:#FF1493'

# Sakura environment
export SAKURA_HOME="$HOME/.sakura"
export EDITOR="nvim"
export VISUAL="nvim"
export TERM="xterm-256color"

# PATH
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/go/bin:$PATH"
