# рҹҢё SakLinux Bash Config
# Sakura's Subsystem for Linux

# History
HISTSIZE=10000
HISTFILESIZE=20000
HISTCONTROL=ignoreboth

# Prompt - Sakura Cherry Blossom Theme
PS1='\[\e[38;5;213m\]рҹҢё \[\e[38;5;206m\]\u\[\e[38;5;251m\]@\[\e[38;5;213m\]saklinux\[\e[38;5;251m\]:\[\e[38;5;141m\]\w\[\e[38;5;251m\]\$ \[\e[0m\]'

# Colors
alias ls='ls --color=auto'
alias ll='ls -la --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'
alias dir='dir --color=auto'

# Modern tools
alias cat='bat --paging=never 2>/dev/null || cat'
alias find='fd 2>/dev/null || find'
alias grep='rg 2>/dev/null || grep'
alias ls='eza --icons 2>/dev/null || ls --color=auto'
alias ll='eza -la --icons 2>/dev/null || ls -la --color=auto'
alias cd='z 2>/dev/null || cd'

# Git shortcuts
alias gs='git status'
alias ga='git add'
alias gc='git commit -m'
alias gp='git push'
alias gl='git log --oneline'
alias gd='git diff'
alias gco='git checkout'
alias gcb='git checkout -b'

# Sakura shortcuts
alias sak='sakura'
alias sak-pet='sak pet'
alias sak-up='sak update'
alias sak-install='sak install'
alias sak-search='sak search'
alias sak-list='sak list'
alias sak-buckets='sak bucket list'

# System
alias ports='netstat -tulanp'
alias ip='ip -c'
alias df='df -h'
alias du='du -h'
alias free='free -h'
alias top='htop'

# Fun
alias sl='echo "рҹҡӮ Choo choo! You meant ls!" && ls'
alias choo='echo "рҹҡӮ Choo choo!"'

